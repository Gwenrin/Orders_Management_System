<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600" prefWidth="1000" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.oms.orders_management_system.MainPage">

    <top>
        <HBox alignment="CENTER_LEFT">
            <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
            <Label text="Orders Management System - Northwind">
                <font><Font size="24" /></font>
            </Label>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="260" spacing="10">
            <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>

            <Label text="Select table" />
            <ComboBox fx:id="tableComboBox" prefHeight="26.0" prefWidth="210.0" />

            <Separator />

            <Label text="Select columns" />
            <ScrollPane fitToWidth="true" prefHeight="300">
                <content>
                    <VBox fx:id="columnsVBox" spacing="5">
                        <padding><Insets bottom="5" left="5" right="5" top="5" /></padding>
                    </VBox>
                </content>
            </ScrollPane>
         <Separator prefWidth="200.0" />

            <Button fx:id="loadButton" text="LOAD DATA" />
        </VBox>
    </left>

    <center>
        <TableView fx:id="dataTable">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
   <right>
      <VBox prefHeight="534.0" prefWidth="179.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Column opertaions">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </padding>
            </Label>
            <ComboBox fx:id="columnComboBox" prefHeight="10.0" prefWidth="158.0">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </ComboBox>
            <Separator prefWidth="200.0" />
            <Button fx:id="avgButton" alignment="CENTER" contentDisplay="CENTER" prefHeight="26.0" prefWidth="78.0" text="AVERAGE">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="minButton" alignment="CENTER" prefHeight="26.0" prefWidth="79.0" text="MINIMUM">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="maxButton" alignment="CENTER" contentDisplay="CENTER" prefHeight="26.0" prefWidth="83.0" text="MAXIMUM">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </Button>
            <Separator prefWidth="200.0" />
            <Button fx:id="sortAscButton" alignment="CENTER" contentDisplay="CENTER" prefHeight="26.0" prefWidth="102.0" text="ASCENDING">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="sortDescButton" alignment="CENTER" contentDisplay="CENTER" prefHeight="26.0" prefWidth="101.0" text="DESCENDING">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </Button>
            <Separator prefWidth="200.0" />
            <Button fx:id="clearResultsButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" text="CLEAR RESULTS">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </right>

</BorderPane>
